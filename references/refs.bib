@inproceedings{harris-ppopp05-composable-memory-transactions,
  author    = {Harris, Tim and Marlow, Simon and Peyton Jones, Simon and Herlihy, Maurice},
  title     = {Composable Memory Transactions},
  booktitle = {PPoPP 2005},
