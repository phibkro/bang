root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

# Lean 4: 2-space, ~100 col (Mathlib convention)
[*.lean]
indent_size = 2
max_line_length = 100

[*.{md,toml,nix,json,yml,yaml,mjs,ts,js}]
indent_size = 2

[Makefile]
indent_style = tab
