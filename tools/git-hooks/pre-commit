#!/usr/bin/env bash
# pre-commit hook — invariants checked before each commit.
# Installation: bash tools/install-hooks.sh
#
# Fast static checks ALWAYS run.
# `just verify` runs IFF .lean files are in the staged set.
#
# To skip verify (e.g., docs-only commit where build is known-stale, or
# mid-WIP commit), set:
#   BANGLANG_SKIP_VERIFY_REASON="..." git commit -m "..."
# This logs the reason so future spelunking knows why.
#
# Hard escape: `git commit --no-verify` bypasses ALL hooks.

set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

# ── 1. No `admit` in staged Lean files ──────────────────────────────────
staged_lean=$(git diff --cached --name-only --diff-filter=ACM \
              | grep -E '\.lean$' || true)

if [ -n "$staged_lean" ]; then
  # Match the `admit` TACTIC (standalone, or after by / ; / => / <;>), NOT the bare
  # word in prose or comments (e.g. Audit.lean's "from a sorry/admit"). The axiom
  # audit (sorryAx) is the real backstop; this is a cheap early static check.
  bad=$(echo "$staged_lean" | xargs -r grep -lE '(^|;|=>|<;>|\bby\b)[[:space:]]*admit\b' 2>/dev/null || true)
  if [ -n "$bad" ]; then
    echo "❌ pre-commit: 'admit' tactic found in staged Lean files:"
    echo "$bad" | sed 's/^/    /'
    echo '   (replace with sorry or close the proof)'
    exit 1
  fi
fi

# ── 2. No hand-rolled `axiom` outside Bang/Spec.lean family ────────────
# NOTE: post-#108 tier-folder paths (the flat Bang/X.lean paths were stale after the restructure).
staged_lean_strict=$(echo "$staged_lean" \
                     | grep -v '^Bang/Spec\.lean$' \
                     | grep -v '^Bang/Core/Typing\.lean$' \
                     | grep -v '^Bang/Meta/LR\.lean$' \
                     | grep -v '^Bang/Core/Semantics\.lean$' \
                     | grep -v '^Bang/Core/Semantics/Eval\.lean$' \
                     | grep -v '^Bang/Backend/Wasm\.lean$' \
                     | grep -v '^Bang/Audit\.lean$' || true)
if [ -n "$staged_lean_strict" ]; then
  # Require `axiom` + whitespace (a real declaration) — `axiom\b` false-matched "axiom-clean" prose.
  bad=$(echo "$staged_lean_strict" | xargs -r grep -lE '^[[:space:]]*axiom[[:space:]]' 2>/dev/null || true)
  if [ -n "$bad" ]; then
    echo "❌ pre-commit: hand-rolled axiom outside the Spec/Syntax/LR/Operational/Compile/Audit family:"
    echo "$bad" | sed 's/^/    /'
    echo "   (axioms belong only in the Phase B stub modules; concretize or move)"
    exit 1
  fi
fi

# ── 3. Statement-change detector ────────────────────────────────────────
# Theorem statements (Bang/Spec.lean PRD) are FROZEN. Modifying a statement
# (vs. filling in a proof body) is the cardinal sin in this project.
# Heuristic: ADD/REMOVE lines starting with `theorem` keyword trigger this.
# False positives possible; explicit ack via env var bypasses.
if [ -n "$staged_lean" ]; then
  theorem_changes=$(git diff --cached -- $staged_lean 2>/dev/null \
                    | grep -E '^[+-][[:space:]]*theorem' || true)
  if [ -n "$theorem_changes" ] && [ -z "${STATEMENT_CHANGE_OK:-}" ]; then
    echo "❌ pre-commit: theorem statement changes detected:"
    echo "$theorem_changes" | head -6 | sed 's/^/    /'
    echo ""
    echo "   Theorem statements are FROZEN (the PRD; per spec-proof-discipline.md)."
    echo "   To commit anyway (e.g., adding a new theorem, intentional refactor):"
    echo "     STATEMENT_CHANGE_OK=\"why this is justified\" git commit -m \"...\""
    exit 1
  fi
fi

# ── 4. Fitness functions (fast, NO Lean build) — ALWAYS ────────────────
# check-primitives · check-adr-links · arch-check (the import-direction V, ADR-0048)
# · check-refs (stale *.md path/link references). These are cheap and need no build,
# so they gate EVERY commit — including docs-only and build-skipped — which is exactly
# when check-refs matters most (a renamed/deleted file leaving dangling doc refs).
# NOT covered by BANGLANG_SKIP_VERIFY_REASON (that is only for the slow/possibly-red
# build); only `git commit --no-verify` bypasses them.
echo "→ pre-commit: running just fitness (primitives · adr-links · adr-check · arch-check · audit-sync · check-refs)"
if ! nix develop --command just fitness > /tmp/bang-fitness.log 2>&1; then
  echo "❌ pre-commit: just fitness failed. Last 20 lines:"
  tail -20 /tmp/bang-fitness.log | sed 's/^/    /'
  echo "   (full log: /tmp/bang-fitness.log) — fix the drift, or 'git commit --no-verify' to bypass."
  exit 1
fi
echo "✓ pre-commit: fitness passed"

# ── 5. `just verify` (full build) IF .lean files are staged ────────────
if [ -z "$staged_lean" ]; then
  echo "✓ pre-commit: passed (no .lean changes; skipping the verify build)"
  exit 0
fi

if [ -n "${BANGLANG_SKIP_VERIFY_REASON:-}" ]; then
  echo "⚠ pre-commit: SKIPPING the just verify build — reason: $BANGLANG_SKIP_VERIFY_REASON"
  echo "   (fitness still ran above — only the Lean build was skipped)"
  exit 0
fi

echo "→ pre-commit: running just verify (set BANGLANG_SKIP_VERIFY_REASON to skip the build)"
# Run via nix develop so lake/just are on PATH
if ! nix develop --command just verify > /tmp/bang-precommit.log 2>&1; then
  echo "❌ pre-commit: just verify failed. Last 20 lines:"
  tail -20 /tmp/bang-precommit.log | sed 's/^/    /'
  echo "   (full log: /tmp/bang-precommit.log)"
  echo "   To commit anyway: BANGLANG_SKIP_VERIFY_REASON=\"...\" git commit --no-verify"
  exit 1
fi

echo "✓ pre-commit: just verify passed"
